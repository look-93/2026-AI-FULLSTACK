<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.the703.dao.UserInfoMapper">

	<!-- 
	     insert update delete 실행한 줄수를 int return해줌 resultType(리턴값) 는 생략
		 select 표의 형식으로 return 해줌 -> rset , resultType
	     id: 메서드명
	     parameterType: 자료형/파라미터 com.the703.dao 들어가있는 객체형식	
	-->
	<!-- 리턴값:resultType,메서드명:id,파라미터:parameterType -->
	<insert id="insert" parameterType="com.the703.dto.UserInfoDto"> <!--  UserInfoDto 받아서 알아서 get/set해줌 -->
		insert into userinfo_e (email ,age) values (#{email} ,#{age})
	</insert>

	<update id="update" parameterType="UserInfoDto"> <!-- mybatis-config.xml에 등록되어있는 alias 읽어옴 -->
		update userinfo_e set email=#{email} , age=#{age} where no=#{no}
	</update>

	<delete id="delete" parameterType="int">
		delete from userinfo_e where no=#{no}
	</delete>

	<select resultType="UserInfoDto" id="selectAll">
		select * from userinfo_e
	</select>
	
	
	<select resultType="UserInfoDto" id="select" parameterType="int"> 
		select * from userinfo_e where no=#{no}
	</select>
  
</mapper>


<!-- 

insert                : insert     into   userinfo_e  (email , age)  values (? , ?) 
select (전체)          : select  * from    userinfo_e
select (해당번호의 읽기) : select  * from    userinfo_e  where no = ? 
update (해당번호 수정)   : update    userinfo_e   set  email=? , age=?  where  no=?
delete (해당번호 삭제)   : delete    from   userinfo_e     where  no=?


 -->