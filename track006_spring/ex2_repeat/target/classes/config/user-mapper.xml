<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.the703.dao.UserMapper">

  <select id="select" resultType="UserDto" parameterType="int">
    select * from users where uno=#{uno}
  </select>
  
  <select id="selectAll" resultType="UserDto">
  	select * from users
  </select>
  
  <insert id="insert" parameterType="UserDto">
  	insert into users(nickname, bpass, email, mobile, udate, bip)
  	value(#{nickname}, #{bpass}, #{email}, #{mobile}, #{udate}, #{bip})  
  </insert>
  
  <update id="update" parameterType="int">  	
  	update users set nickname=#{nickname} where uno=#{uno}
  </update>
  
</mapper>






