<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.the703.dao.BoardMapper">

	<select id="selectAll" resultType="BoardDto">
		select * from mvcboard2
	</select>

	<select id="select" resultType="BoardDto" parameterType="int">
		select * from mvcboard2 where bno=#{bno}
	</select>
	
	<insert id="insert" parameterType="BoardDto">	
		insert into mvcboard2 (bname, bpass, btitle, bcontent, bdate, bhit, bip)
		value(#{bname}, #{bpass}, #{btitle}, #{bcontent}, #{bdate}, #{bhit}, #{bip});
	</insert>
	
	<update id="update" parameterType="BoardDto">
		update mvcboard2 set  bname=#{bname} where bno=#{bno}	 
	</update>
	
	<delete id="delete" parameterType="int">
		delete from mvcboard2 where bno=#{bno}
	</delete>
</mapper>