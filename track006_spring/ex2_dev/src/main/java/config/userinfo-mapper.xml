<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.the703.dao.UserInfoMapper">

	<insert id="insert" parameterType="UserInfoDto">
		insert into userinfo_e(email,
		age) value (#{email}, #{age})
	</insert>

	<select id="selset" resultType="UserInfoDto" parameterType="int">
		select * from userinfo_e where no = #{no}
	</select>

	<select id="selsetAll" resultType="UserInfoDto">
		select * from userinfo_e 
	</select>
	
	<update id="update" parameterType="UserInfoDto">
		update userinfo_e set email=#{email} where no=#{no}
	</update>
	
	<delete id="delete" parameterType="int">
		delete from userinfo_e where no = #{no}
	</delete>

</mapper>
