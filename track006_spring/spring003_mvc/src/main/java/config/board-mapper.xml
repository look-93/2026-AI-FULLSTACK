<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.the703.dao.MvcBoardMapper">

	<select id="selectAll" resultType="MvcBoardDto">
		select * from mvcboard2
	</select>

	<select id="select" resultType="MvcBoardDto" parameterType="int">
		select * from mvcboard2 where bno=#{bno}
	</select>
	
	<insert id="insert" parameterType="MvcBoardDto">
		insert into mvcboard2 (bname, bpass, btitle, bcontent, bip, bfile) 
		value(#{bname}, #{bpass}, #{btitle}, #{bcontent}, #{bip}, #{bfile})
	</insert>
	
	<update id="update" parameterType="MvcBoardDto">
		update mvcboard2 
		   set btitle=#{btitle}, bcontent=#{bcontent}, bfile=#{bfile}  
		 where bno=#{bno} and bpass=#{bpass}
	</update>
	
	<delete id="delete" parameterType="int">
		delete from mvcboard2 where bno=#{bno} <!-- and bpass=#{bpass} -->
	</delete>
	
	<select id="detail" parameterType="int"  resultType="MvcBoardDto">
		select * from mvcboard2 where bno=#{bno}
	</select>
	
	<!-- 조회수 올리기 -->
	<update id="updateBhit" parameterType="int">
		update mvcboard2 set bhit = bhit+1 where bno=#{bno} 	
	</update>
	
	<!-- paging -->
	<select id="select10" resultType="MvcBoardDto" parameterType="java.util.HashMap">
		select * from mvcboard2 order by bno desc limit #{start}, ${end}
	</select>
	
	<select id="selectCnt" resultType="int">
		select count(*) from mvcboard2
	</select>

</mapper>